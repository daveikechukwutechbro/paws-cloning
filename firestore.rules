rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      
      allow create: if request.resource.data.id == userId;
      
      allow update: if request.resource.data.id == userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'balance',
            'username',
            'isPremium',
            'referralRewardClaimed',
            'referralCount',
            'premiumReferralCount',
            'referralEarnings',
            'referralHourlyCount',
            'referralDailyCount',
            'lastReferralHourReset',
            'lastReferralDayReset',
            'friendsList',
            'tierLevel',
            'tierRewardsClaimed',
            'lastReferralAt',
            'referredBy',
            'lastTaskCompletedAt',
            'completedTasks',
            'miningUpgrades',
            'miningUpgradedAt',
            'upgrade_taps',
            'upgrade_energy',
            'upgrade_timer'
          ])
          || request.auth != null
        );
      
      allow delete: if false;
    }

    match /referrals/{referralId} {
      allow read: if true;
      allow create: if referralId.startsWith('ref_');
      allow update: if referralId.startsWith('ref_')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'rewardAmount',
          'qualifiedAt',
          'rewardedAt',
          'rejectedAt',
          'rejectionReason'
        ]);
      allow delete: if false;
    }

    match /reward_ledger/{entryId} {
      allow read: if true;
      allow create: if entryId.startsWith('reward_');
      allow update: if false;
      allow delete: if false;
    }
  }
}
